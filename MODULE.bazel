# System deps — source builds via rules_foreign_cc cmake()/configure_make() -
# These replace the prebuilt zips from OpenEnroth_Dependencies.
# FFmpeg (Linux/macOS): configure_make() source build.
# FFmpeg (Windows): prebuilt — configure requires bash/MSYS2 (deferred).
# FFmpeg (Android): prebuilt — NDK cross-compilation not yet configured.

http_archive(
    name = "zlib_src",
    url = "https://github.com/madler/zlib/archive/04f42ceca40f73e2978b50e93806c2a18c1281fc.tar.gz",
    strip_prefix = "zlib-04f42ceca40f73e2978b50e93806c2a18c1281fc",
    build_file = "//bazel/deps:zlib_src.BUILD",
    patches = [
        # Patch 1: mark the shared lib EXCLUDE_FROM_ALL so it isn't built by default,
        # and add OPTIONAL to its install() so cmake --install doesn't fail when the
        # shared lib wasn't built. zlib 1.2.13 always builds both SHARED and STATIC
        # unconditionally; this patch respects BUILD_SHARED_LIBS=OFF.
        "//bazel/patches:zlib_exclude_shared.patch",
        # Patch 2: strip Bazel timestamp-redaction flags (-D__DATE__=redacted etc.)
        # that conflict with macOS Xcode 16.3 system headers (_stdio.h:318).
        "//bazel/patches:zlib_strip_injected_flags.patch",
        # Patch 3: zutil.h defines fdopen(fd,mode)=NULL on TARGET_OS_MAC, but macOS
        # always has fdopen. The macro causes _stdio.h:318 to fail when fdopen() is
        # declared after the macro is defined. Add !defined(__APPLE__) guard.
        "//bazel/patches:zlib_fix_fdopen_apple.patch",
    ],
    patch_args = ["-p1"],
    sha256 = "90f43a9c998740e8a0db24b0af0147033db2aaaa99423129abbd76640757cac9",
)

