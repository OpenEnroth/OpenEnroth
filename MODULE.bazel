"""OpenEnroth Bazel module definition."""

module(
    name = "openenroth",
    version = "0.0.0",
)

# ─── Core Bazel rules ────────────────────────────────────────────────────────

bazel_dep(name = "rules_cc", version = "0.2.17")
bazel_dep(name = "platforms", version = "1.0.0")
bazel_dep(name = "bazel_skylib", version = "1.8.2")

# ─── Testing ─────────────────────────────────────────────────────────────────

bazel_dep(name = "googletest", version = "1.17.0")

# ─── rules_foreign_cc — wraps CMake/Make deps (used for LuaJIT, SDL3, etc.) ──

bazel_dep(name = "rules_foreign_cc", version = "0.11.1")

# Patch rules_foreign_cc to remove an unused `load("@rules_cc//cc:defs.bzl", "cc_library")`
# from the glib_dev build_file_content. That load fails under Bazel 8 / Bzlmod because
# rules_foreign_cc 0.11.1 doesn't declare rules_cc as a bazel_dep, so @rules_cc is not
# visible from the glib_dev synthetic repository. The load is completely unused (only
# cc_import is present, which is a native Bazel rule).
single_version_override(
    module_name = "rules_foreign_cc",
    version = "0.11.1",
    patches = [
        # Bug 1: glib_dev build_file_content has an unused load("@rules_cc//...") that
        # fails under Bazel 8 because rules_foreign_cc 0.11.1 doesn't declare rules_cc
        # as a non-dev bazel_dep (it's only a dev_dependency).
        "//bazel/patches:rules_foreign_cc_fix_glib.patch",
        # Bug 2: full_label() uses native.repository_name() which returns @@module+
        # under Bazel 8 Bzlmod. That canonical form is not resolvable from within the
        # same module in $(location ...) expressions.
        "//bazel/patches:rules_foreign_cc_fix_full_label.patch",
        # Bug 3: pkgconfig_build.bzl accesses make_data.target.files unconditionally.
        # When preinstalled_make_toolchain is used, make_data.target is None (the make
        # binary is on PATH, not a Bazel target). This crashes with NoneType error.
        "//bazel/patches:rules_foreign_cc_fix_pkgconfig.patch",
    ],
    patch_strip = 1,
)

# ─── Android ─────────────────────────────────────────────────────────────────

bazel_dep(name = "rules_android", version = "0.6.0")

# rules_android_ndk provides the Android NDK C++ toolchain for cc_binary cross-compilation.
# It reads ANDROID_NDK_HOME from the environment and registers toolchains for all ABIs
# (arm64-v8a, armeabi-v7a, x86_64). Required for --platforms=//bazel/platforms:android_*
# targets to find a CC toolchain.
bazel_dep(name = "rules_android_ndk", version = "0.1.3")

# Patch rules_android_ndk to create a stub repo (instead of fail()) when
# ANDROID_NDK_HOME is not set. This lets Windows/macOS/Linux non-Android builds
# succeed even though they don't have an NDK; register_toolchains("@androidndk//:all")
# resolves to the empty set for the stub. Android CI builds set ANDROID_NDK_HOME
# before invoking Bazel, so they get the real toolchains.
single_version_override(
    module_name = "rules_android_ndk",
    version = "0.1.3",
    patches = ["//bazel/patches:rules_android_ndk_stub_no_ndk.patch"],
    patch_strip = 1,
)

android_ndk_repository_extension = use_extension("@rules_android_ndk//:extension.bzl", "android_ndk_repository_extension")
use_repo(android_ndk_repository_extension, "androidndk")
register_toolchains("@androidndk//:all")

