# System dependency targets.
# Each cc_library selects the correct prebuilt archive for the current platform+arch.
# All src/ targets reference these (e.g. //bazel/system:sdl3).

# ─── SDL3 ────────────────────────────────────────────────────────────────────

cc_library(
    name = "sdl3",
    deps = select({
        "//bazel/platforms:linux_x86_64":      ["@oe_deps_linux_x86_64//:sdl3"],
        "//bazel/platforms:linux_x86":         ["@oe_deps_linux_x86//:sdl3"],
        "//bazel/platforms:darwin_arm64":      ["@oe_deps_darwin_arm64//:sdl3"],
        "//bazel/platforms:darwin_x86_64":     ["@oe_deps_darwin_x86_64//:sdl3"],
        "//bazel/platforms:windows_x86_64":    ["@oe_deps_windows_x86_64//:sdl3"],
        "//bazel/platforms:windows_x86":       ["@oe_deps_windows_x86//:sdl3"],
        "//bazel/platforms:android_arm64_v8a": ["@oe_deps_android_arm64//:sdl3"],
        "//bazel/platforms:android_armeabi_v7a": ["@oe_deps_android_arm32//:sdl3"],
        "//bazel/platforms:android_x86_64":    ["@oe_deps_android_x86_64//:sdl3"],
    }),
    visibility = ["//visibility:public"],
)

