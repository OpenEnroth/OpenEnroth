# ─── LuaJIT ──────────────────────────────────────────────────────────────────
# Windows: use CMake-prebuilt lib (rules_foreign_cc make() fails on Windows/MSVC).
# Other platforms: use source build from @luajit http_archive.

cc_library(
    name = "luajit",
    deps = select({
        "@platforms//os:windows": ["@luajit_windows//:luajit_prebuilt"],
        "//conditions:default":   ["@luajit//:luajit"],
    }),
    visibility = ["//visibility:public"],
)

# ─── OpenGL ──────────────────────────────────────────────────────────────────
# System-provided on all platforms — no prebuilt archive needed.

cc_library(
    name = "opengl",
    linkopts = select({
        "@platforms//os:linux":   ["-lGL"],
        "@platforms//os:macos":   ["-framework OpenGL"],
        "@platforms//os:windows": ["opengl32.lib"],
        "@platforms//os:android": ["-lGLESv2", "-lEGL"],
        "//conditions:default":   [],
    }),
    visibility = ["//visibility:public"],
)
