# All engine_graphics .cpp files are compiled in //src/Engine:engine_impl
# to break the circular dependency:
#   engine_graphics.cpp -> Engine/Engine.h (from :engine) or Renderer/Renderer.h (from engine_graphics_renderer)
#   engine -> engine_graphics (headers)
#   engine_graphics_renderer -> engine_graphics (headers)
exports_files(
    [
        "BSPModel.cpp",
        "BspRenderer.cpp",
        "Camera.cpp",
        "ClippingFunctions.cpp",
        "Collisions.cpp",
        "DecalBuilder.cpp",
        "FrameLimiter.cpp",
        "Image.cpp",
        "ImageLoader.cpp",
        "Indoor.cpp",
        "LightmapBuilder.cpp",
        "LightsStack.cpp",
        "LocationFunctions.cpp",
        "Outdoor.cpp",
        "OutdoorTerrain.cpp",
        "Overlays.cpp",
        "PaletteManager.cpp",
        "ParticleEngine.cpp",
        "PortalFunctions.cpp",
        "Sprites.cpp",
        "TileGenerator.cpp",
        "TurnBasedOverlay.cpp",
        "Viewport.cpp",
        "Vis.cpp",
        "Weather.cpp",
    ],
    visibility = ["//src/Engine:__pkg__"],
)

cc_library(
    name = "engine_graphics",
    srcs = [],
    hdrs = [
        "AtlasLayout.h",
        "BSPModel.h",
        "BspRenderer.h",
        "Camera.h",
        "ClippingFunctions.h",
        "Collisions.h",
        "DecalBuilder.h",
        "FaceEnums.h",
        "FrameLimiter.h",
        "Image.h",
        "ImageLoader.h",
        "Indoor.h",
        "LightmapBuilder.h",
        "LightsStack.h",
        "LocationFunctions.h",
        "LocationInfo.h",
        "LocationTime.h",
        "Outdoor.h",
        "OutdoorTerrain.h",
        "Overlays.h",
        "PaletteManager.h",
        "ParticleEngine.h",
        "PortalFunctions.h",
        "RenderEntities.h",
        "Sprites.h",
        "SpriteEnums.h",
        "SpriteEnumFunctions.h",
        "TileGenerator.h",
        "TurnBasedOverlay.h",
        "Viewport.h",
        "Vis.h",
        "Weather.h",
    ],
    deps = [
        "//src/Engine:engine_base",
        "//src/Engine/Graphics/Renderer:engine_texture_id",
        "//src/Engine/Time:engine_time",
        "//src/Utility:utility",
        "//src/Library/Serialization:library_serialization",
        "//src/Library/Color:library_color",
        "//src/Library/Image:library_image",
        "@glm//:glm",
        "//bazel/system:opengl",
        "//bazel/system:luajit",
        "@sol2//:sol2",
        # glad is PRIVATE
        "//thirdparty/glad:glad",
    ],
    visibility = ["//visibility:public"],
)
